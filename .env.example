# API under test – base URL sans slash final.
BASE_URL=http://localhost:5054

# TOTAL_ITEMS est passé obligatoirement en argument des scripts run (ex. ./run/run-load-test-short.sh 10000).
# PAGE_SIZE=100 (défaut dans les scripts si non défini)

# InfluxDB 2 (must match docker-compose and Grafana datasource)
INFLUXDB_ORG=k6
INFLUXDB_BUCKET=k6
INFLUXDB_TOKEN=k6-influxdb-token
INFLUXDB_ADDR=http://localhost:8086
INFLUXDB_ADMIN_PASSWORD=adminpassword

# Grafana (anonymous access enabled: no login required)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000
