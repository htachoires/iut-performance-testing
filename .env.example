# API under test – set this to your target base URL (no trailing slash)
BASE_URL=http://localhost:5054

# InfluxDB 2 (must match docker-compose and Grafana datasource)
INFLUXDB_ORG=k6
INFLUXDB_BUCKET=k6
INFLUXDB_TOKEN=k6-influxdb-token
INFLUXDB_ADDR=http://localhost:8086
INFLUXDB_ADMIN_PASSWORD=adminpassword

# Grafana (anonymous access enabled: no login required)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000
